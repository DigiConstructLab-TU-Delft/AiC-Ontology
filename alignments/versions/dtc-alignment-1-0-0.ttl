@prefix : <https://w3id.org/aic/dtc-alignment#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix terms: <http://purl.org/dc/terms/> .
@prefix aic: <https://w3id.org/aic#> .
@prefix dtc: <https://dtc-ontology.cms.ed.tum.de/ontology/v2#> .
@base <https://w3id.org/aic/dtc-alignment#> .

<https://w3id.org/aic/dtc-alignment> rdf:type owl:Ontology ;
                                      owl:versionIRI <https://w3id.org/aic/dtc-alignment/1.0.0> ;
                                      owl:imports <https://dtc-ontology.cms.ed.tum.de/ontology/v2> ,
                                                  <https://w3id.org/aic/1.1.0> ;
                                      terms:contributor "Daniel Hall" ,
                                                        "Hans Wamelink" ,
                                                        "Pieter Pauwels" ;
                                      terms:creator "Irfan Čustović" ,
                                                    "Jianpeng Cao" ,
                                                    "Ranjith Soman" ;
                                      terms:description "Alignment module mapping selected classes from DTC V2 to AiC v1.1.0 ."@en ;
                                      terms:license <https://creativecommons.org/licenses/by/4.0/> ;
                                      terms:modified "2026-06-20" ;
                                      terms:title "DTC to AIC alignment"@en ;
                                      owl:versionInfo "1.0.0" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/contributor
terms:contributor rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/creator
terms:creator rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/description
terms:description rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/license
terms:license rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/modified
terms:modified rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
terms:title rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

aic:requiresResource owl:equivalentProperty dtc:requiresResource .
aic:isOperatingIn owl:equivalentProperty dtc:workesInZone .
aic:targets owl:equivalentProperty dtc:hasTarget .

#################################################################
#    Classes
#################################################################

aic:Process owl:equivalentClass dtc:Process . 
aic:WorkingZone rdfs:subClassOf aic:Zone . 
dtc:AsPlannedWorker rdfs:subClassOf aic:ConstructionAgent . 
dtc:AsPerformedWorker rdfs:subClassOf aic:ConstructionAgent .
dtc:AsPlannedMaterial rdfs:subClassOf aic:Material . 
dtc:AsPerformedMaterial rdfs:subClassOf aic:Material . 
dtc:AsPlannedEquipment rdfs:subClassOf aic:Equipment . 
dtc:AsPerformedEquipment rdfs:subClassOf aic:Equipment . 
dtc:AsPlannedTemporaryEquipment rdfs:subClassOf aic:Equipment .  
dtc:AsPerformedTemporaryEquipment rdfs:subClassOf aic:Equipment .  
