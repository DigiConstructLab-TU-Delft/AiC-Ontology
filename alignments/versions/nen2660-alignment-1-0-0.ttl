@prefix : <https://w3id.org/aic/nen2260-alignment#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix terms: <http://purl.org/dc/terms/> .
@prefix aic: <https://w3id.org/aic#> .
@prefix nen2660: <https://w3id.org/nen2660/def#> .
@base <https://w3id.org/aic/nen2260-alignment#> .

<https://w3id.org/aic/nen2260-alignment> rdf:type owl:Ontology ;
                                      owl:versionIRI <https://w3id.org/aic/nen2260-alignment/1.0.0> ;
                                      owl:imports <https://w3id.org/nen2660/def> ,
                                                  <https://w3id.org/aic/1.1.0> ;
                                      terms:contributor "Daniel Hall" ,
                                                        "Hans Wamelink" ,
                                                        "Pieter Pauwels" ;
                                      terms:creator "Irfan Čustović" ,
                                                    "Jianpeng Cao" ,
                                                    "Ranjith Soman" ;
                                      terms:description "Alignment module mapping selected classes from NEN2660 (NEN 2660-2:2022) to AiC v1.1.0 ."@en ;
                                      terms:license <https://creativecommons.org/licenses/by/4.0/> ;
                                      terms:modified "2026-06-20" ;
                                      terms:title "NEN2660 to AIC alignment"@en ;
                                      owl:versionInfo "1.0.0" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/contributor
terms:contributor rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/creator
terms:creator rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/description
terms:description rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/license
terms:license rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/modified
terms:modified rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
terms:title rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

aic:hasElement rdfs:subPropertyOf nen2660:contains . 

aic:targets rdfs:subPropertyOf nen2660:transforms .

#################################################################
#    Classes
#################################################################

aic:Process rdfs:subClassOf nen2660:Activity .
 
aic:ConstructionAgent rdfs:subClassOf nen2660:Entity . 
aic:Element rdfs:subClassOf nen2660:Entity . 
aic:Resource rdfs:subClassOf nen2660:Entity . 
aic:Zone owl:equivalentClass nen2660:SpatialZone . 

aic:OperationMode rdfs:subClassOf nen2660:State .
aic:ProcessState rdfs:subClassOf nen2660:State . 
