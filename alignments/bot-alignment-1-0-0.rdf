        <terms:creator>Ranjith Soman</terms:creator>
        <terms:description xml:lang="en">Alignment module mapping selected classes from BOT v0.3.2 to AiC v1.1.0 .</terms:description>
        <terms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
        <terms:modified>2026-06-20</terms:modified>
        <terms:title xml:lang="en">BOT to AIC alignment</terms:title>
        <owl:versionInfo>1.0.0</owl:versionInfo>
    </owl:Ontology>
    


