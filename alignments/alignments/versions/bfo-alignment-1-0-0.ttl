<https://w3id.org/aic/bfo-alignment> rdf:type owl:Ontology ;
                                      owl:versionIRI <https://w3id.org/aic/bfo-alignment/1.0.0> ;
                                      owl:imports <http://purl.obolibrary.org/obo/bfo/2019-08-26/bfo.owl> ,
