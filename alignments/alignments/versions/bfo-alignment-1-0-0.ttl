                                      terms:contributor "Daniel Hall" ,
                                                        "Hans Wamelink" ,
                                                        "Pieter Pauwels" ;
                                      terms:creator "Irfan Čustović" ,
                                                    "Jianpeng Cao" ,
                                                    "Ranjith Soman" ;
                                      terms:description "Alignment module mapping selected classes from BFO v2.0 to AiC v1.1.0 ."@en ;
                                      terms:license <https://creativecommons.org/licenses/by/4.0/> ;
                                      terms:modified "2026-06-20" ;
                                      terms:title "BFO to AIC alignment"@en ;
                                      owl:versionInfo "1.0.0" .

