@prefix : <https://w3id.org/aic/ioc-alignment#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix terms: <http://purl.org/dc/terms/> .
@prefix aic: <https://w3id.org/aic#> .
@prefix ioc: <http://w3id.org/ioc#> .
@base <https://w3id.org/aic/ioc-alignment#> .

<https://w3id.org/aic/ioc-alignment> rdf:type owl:Ontology ;
                                      owl:versionIRI <https://w3id.org/aic/ioc-alignment/1.0.0> ;
                                      owl:imports <http://w3id.org/ioc> ,
                                                  <https://w3id.org/aic/1.1.0> ;
                                      terms:contributor "Daniel Hall" ,
                                                        "Hans Wamelink" ,
                                                        "Pieter Pauwels" ;
                                      terms:creator "Irfan Čustović" ,
                                                    "Jianpeng Cao" ,
                                                    "Ranjith Soman" ;
                                      terms:description "Alignment module mapping selected classes from IOC v0.5 to AiC v1.1.0 ."@en ;
                                      terms:license <https://creativecommons.org/licenses/by/4.0/> ;
                                      terms:modified "2026-06-20" ;
                                      terms:title "IOC to AIC alignment"@en ;
                                      owl:versionInfo "1.0.0" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/contributor
terms:contributor rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/creator
terms:creator rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/description
terms:description rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/license
terms:license rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/modified
terms:modified rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
terms:title rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

aic:hasPredecessor owl:equivalentProperty ioc:hasPredecessor .
aic:hasSuccessor owl:equivalentProperty ioc:hasSuccessor .

#################################################################
#    Classes
#################################################################

aic:Process owl:equivalentClass ioc:Process . 
aic:ProcessState owl:equivalentClass ioc:Status . 
aic:Resource rdfs:subClassOf ioc:Resource . 
aic:AgentCapability rdfs:subClassOf ioc:Capability . 
